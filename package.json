{
  "name": "juice-db",
  "version": "0.1.0",
  "description": "Lightweight Mac database client for Postgres, MySQL, and SQL Server",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --dir",
    "run:app": "npm run package && open release/mac-arm64/JuiceDB.app",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "ag-grid-community": "^32.0.0",
    "ag-grid-react": "^32.0.0",
    "mssql": "^11.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "zustand": "^4.0.0"
  },
  "build": {
    "appId": "com.juicedb.app",
    "productName": "JuiceDB",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{ "target": "dir", "arch": ["arm64"] }],
      "identity": null
    },
    "asar": true,
    "nativeRebuilder": "sequential",
    "afterPack": "./scripts/afterPack.js"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/mssql": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "~42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  }
}
